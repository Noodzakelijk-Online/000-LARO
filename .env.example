# LARO environment template. Copy to .env and set only the values you need.
# Never commit a real .env file.

# Electron/tRPC runtime. The packaged desktop app generates JWT_SECRET and
# COOKIE_SECRET in <userData>/laro-secrets.json.
NODE_ENV=development
PORT=3000
HOST=127.0.0.1
# Optional Vite development proxy target when the API uses a non-default port.
VITE_LARO_API_URL=http://127.0.0.1:3000
API_BODY_LIMIT=10mb
JWT_SECRET=
COOKIE_SECRET=

# Electron/tRPC database and evidence storage.
DATABASE_URL=
LOCAL_STORAGE_DIR=
# Standalone server only: path-delimited roots the server may scan for local evidence.
# The packaged desktop uses its native folder picker instead.
LOCAL_SCAN_ROOTS=
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=eu-west-1

# Optional AI providers for the Electron/tRPC runtime.
# The current provider-backed LLM adapter uses a Forge-compatible endpoint.
FORGE_API_URL=
FORGE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Optional connectors for the Electron/tRPC runtime.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3000
TRELLO_API_KEY=
TELEGRAM_BOT_TOKEN=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Flask command-center runtime. run_local.ps1 uses this dedicated port so both
# runtimes can be configured from the same .env without a PORT collision.
LARO_FLASK_PORT=8768

# The Flask session signing key. Generate a long, random local value.
SECRET_KEY=
LARO_HOST=127.0.0.1
LARO_DEBUG=false
LARO_AUTH_DATABASE_PATH=instance/laro_auth.sqlite3
# Optional password reset delivery. The URL template must contain {token}.
# SMTP_HOST/PORT/USER/PASS/FROM above are reused by the Flask runtime.
LARO_PASSWORD_RESET_URL_TEMPLATE=http://127.0.0.1:8768/reset-password.html?token={token}
SMTP_STARTTLS=true

# Persistent local-first ledger. This path stays ignored by Git.
LARO_LEDGER_DATABASE_URL=sqlite:///instance/laro_ledger.sqlite3
LARO_UPLOAD_ROOT=instance/uploads
LARO_MAX_UPLOAD_BYTES=26214400
# Maximum total uncompressed size of an approved case-bundle ZIP.
LARO_BUNDLE_MAX_BYTES=104857600
LARO_TOKEN_STORE_DIR=tokens
# The only account allowed to use the localhost-only session bootstrap used by
# the local command dashboards. Use password login for any additional account.
LARO_LOCAL_ACCOUNT_EMAIL=robert.local@laro
# Optional: provide a Fernet key instead of using the local ignored vault key file.
LARO_TOKEN_ENCRYPTION_KEY=

# Optional local-only deep document reading. LARO only accepts a loopback Ollama
# endpoint, reads long sources in bounded batches, and discards model observations
# that do not cite literal source text. MAX_CHARS is per model batch, not per case.
LARO_ANALYSIS_PROVIDER=rule_based
LARO_OLLAMA_BASE_URL=http://127.0.0.1:11434
LARO_OLLAMA_MODEL=
LARO_OLLAMA_TIMEOUT_SECONDS=45
LARO_LOCAL_ANALYSIS_MAX_CHARS=20000

# Optional Google Gmail/Drive read-only OAuth connection shared by both runtimes.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8768/api/google/oauth/callback
