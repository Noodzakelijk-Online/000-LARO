# Local LARO runtime. Copy to .env and set only the values you need.

# The Flask session signing key. Generate a long, random local value.
SECRET_KEY=

# LARO listens here by default. Use another free local port if needed.
PORT=8768
LARO_HOST=127.0.0.1
LARO_DEBUG=false

# Persistent local-first ledger. This path stays ignored by Git.
LARO_LEDGER_DATABASE_URL=sqlite:///instance/laro_ledger.sqlite3
LARO_UPLOAD_ROOT=instance/uploads
LARO_MAX_UPLOAD_BYTES=26214400
LARO_TOKEN_STORE_DIR=tokens
# The only account allowed to use the localhost-only session bootstrap used by
# the local command dashboards. Use password login for any additional account.
LARO_LOCAL_ACCOUNT_EMAIL=robert.local@laro
# Optional: provide a Fernet key instead of using the local ignored vault key file.
LARO_TOKEN_ENCRYPTION_KEY=

# Optional local-only deep document reading. LARO only accepts a loopback Ollama
# endpoint and discards any model observation that does not cite source text.
LARO_ANALYSIS_PROVIDER=rule_based
LARO_OLLAMA_BASE_URL=http://127.0.0.1:11434
LARO_OLLAMA_MODEL=
LARO_OLLAMA_TIMEOUT_SECONDS=45
LARO_LOCAL_ANALYSIS_MAX_CHARS=20000

# Optional Google Gmail/Drive read-only OAuth connection.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8768/api/google/oauth/callback
