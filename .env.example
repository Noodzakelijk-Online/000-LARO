# LARO environment template (Phase 030).
# Copy to `.env` for local/standalone-server runs. NEVER commit a real .env.
# The packaged desktop app no longer ships a bundled .env; it generates
# per-install JWT_SECRET / COOKIE_SECRET / LOCAL_AGENT_TOKEN into
# <userData>/laro-secrets.json on first run (see src-main/index.ts).

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Security (REQUIRED in production; generate strong random values) ---
# In production the server refuses to start if these are missing or set to the
# insecure defaults. Generate with: openssl rand -hex 32
JWT_SECRET=
COOKIE_SECRET=
# Per-install desktop scanner token (auto-generated by the desktop app).
LOCAL_AGENT_TOKEN=

# --- Database / storage ---
DATABASE_URL=
# When AWS_S3_BUCKET is unset, evidence is stored on local disk (LOCAL_STORAGE_DIR).
LOCAL_STORAGE_DIR=
AWS_S3_BUCKET=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=eu-west-1

# --- AI provider (optional; without a key, LLM features run in labelled mock/
#     deterministic-fallback mode) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# --- OAuth evidence connectors (optional; providers are shown as "not
#     available" until configured — Phase 012) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
TRELLO_API_KEY=
TELEGRAM_BOT_TOKEN=

# --- Email (system email: password reset) ---
SENDGRID_API_KEY=
