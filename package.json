{
  "name": "laro-desktop",
  "version": "1.3.0",
  "description": "LARO - Legal Aid Reach Out",
  "author": "Noodzakelijk Online",
  "main": "dist/main/src-main/index.js",
  "engines": {
    "node": ">=22.12 <23"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "npm run rebuild:electron && tsc -p tsconfig.main.json && cross-env NODE_ENV=development electron dist/main/src-main/index.js",
    "dev:server": "npm run rebuild:node && cross-env NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:renderer && npm run build:main && npm run build:server",
    "build:renderer": "node scripts/build-renderer.mjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "dist": "npm run build && npm run rebuild:electron && electron-builder",
    "dist:win": "npm run build && npm run rebuild:electron && electron-builder --win",
    "dist:store": "npm run build && npm run rebuild:electron && electron-builder --config electron-builder.store.cjs --win appx --publish never",
    "dist:mac": "npm run build && npm run rebuild:electron && electron-builder --mac",
    "dist:linux": "npm run build && npm run rebuild:electron && electron-builder --linux",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run rebuild:node && vitest run",
    "test:watch": "vitest",
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "audit:deps": "npm audit",
    "db:backup": "tsx scripts/backup.ts",
    "db:restore": "tsx scripts/backup.ts --restore",
    "db:validate": "tsx scripts/backup.ts --validate",
    "db:readiness": "npm run rebuild:node && tsx scripts/data-readiness.ts",
    "recovery:drill": "tsx scripts/recovery-drill.ts",
    "serve": "npm run rebuild:node && npm run build:server && cross-env NODE_ENV=production node dist/server/server/index.js",
    "docker:build": "docker build -t laro-server .",
    "docker:run": "docker run --rm -p 3000:3000 --env-file .env laro-server",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "verify:electron-native": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/verify-electron-sqlite.cjs",
    "release:check": "node scripts/release-acceptance.mjs",
    "traceability": "node scripts/traceability.mjs --write",
    "gate": "node scripts/stabilization-gate.mjs",
    "verify": "npm run gate",
    "scan:no-excuses": "node scripts/no-excuses-scan.mjs --write",
    "scan:safety": "node scripts/account-safety-check.mjs --write",
    "preflight": "node scripts/prod-preflight.mjs",
    "readiness": "npm run rebuild:node && node scripts/operator-readiness.mjs",
    "readiness:production": "npm run rebuild:node && node scripts/operator-readiness.mjs --production",
    "regression:baseline": "node scripts/regression-baseline.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@aws-sdk/s3-request-presigner": "^3.1022.0",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^4.18.0",
    "@tesseract.js-data/eng": "1.0.0",
    "@tesseract.js-data/nld": "1.0.0",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "@types/archiver": "^7.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "archiver": "^7.0.1",
    "axios": "^1.6.8",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.1.2",
    "express": "^4.19.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.363.0",
    "mammoth": "^1.12.0",
    "mime-types": "^2.1.35",
    "nanoid": "^3.3.7",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.3",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "recharts": "^2.12.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^1.4.41",
    "superjson": "^1.13.1",
    "tailwind-merge": "^2.2.2",
    "tesseract.js": "7.0.0",
    "uuid": "^11.1.1",
    "wouter": "^3.1.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.23.1",
    "typescript": "^5.4.5",
    "vite": "^8.1.4",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.laro.desktop",
    "productName": "LARO Desktop",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "node_modules",
      "drizzle",
      "package.json"
    ],
    "asarUnpack": [
      "drizzle/**/*",
      "node_modules/@tesseract.js-data/eng/4.0.0/eng.traineddata.gz",
      "node_modules/@tesseract.js-data/nld/4.0.0/nld.traineddata.gz",
      "node_modules/bmp-js/**/*",
      "node_modules/is-url/**/*",
      "node_modules/regenerator-runtime/**/*",
      "node_modules/tesseract.js/**/*",
      "node_modules/tesseract.js-core/**/*",
      "node_modules/wasm-feature-detect/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "legal-taxonomy-mapping.json",
          "legal-keywords.json"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.legal-aid"
    },
    "win": {
      "icon": "build/icon.png",
      "target": "portable"
    },
    "appx": {
      "applicationId": "LARO.Desktop",
      "displayName": "LARO Desktop",
      "languages": [
        "en-US",
        "nl-NL"
      ],
      "artifactName": "LARO-Desktop-${version}-Store-${arch}.${ext}"
    }
  }
}
