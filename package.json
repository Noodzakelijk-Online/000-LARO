{
  "name": "laro-desktop",
  "version": "1.0.0",
  "description": "LARO - Legal Aid Reach Out",
  "main": "dist/main/src-main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && cross-env NODE_ENV=development electron dist/main/src-main/index.js",
    "dev:server": "tsx server/index.ts",
    "build": "npm run build:renderer && npm run build:main && npm run build:server",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:server": "tsc -p tsconfig.server.json",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@aws-sdk/s3-request-presigner": "^3.1022.0",
    "@azure/msal-node": "^5.1.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^4.18.0",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "@types/archiver": "^7.0.0",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/nodemailer": "^7.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "@types/socket.io": "^3.0.1",
    "@types/stripe": "^8.0.416",
    "archiver": "^7.0.1",
    "axios": "^1.6.8",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.3",
    "electron-log": "^5.1.2",
    "express": "^4.19.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "isomorphic-fetch": "^3.0.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.363.0",
    "mammoth": "^1.12.0",
    "mime-types": "^2.1.35",
    "nanoid": "^3.3.7",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "recharts": "^2.12.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^1.4.41",
    "stripe": "^21.0.1",
    "superjson": "^1.13.1",
    "tailwind-merge": "^2.2.2",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "wouter": "^3.1.2",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.2",
    "electron": "^29.2.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vitest": "^1.4.0"
  },
  "build": {
    "appId": "com.laro.desktop",
    "productName": "LARO Desktop",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "node_modules",
      "drizzle",
      "package.json",
      ".env"
    ],
    "asarUnpack": [
      "drizzle/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.legal-aid"
    },
    "win": {
      "target": "portable"
    }
  }
}
