{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ESNext",
    "sourceMap": true,
    "outDir": "dist/main",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noEmit": false,
    "composite": true,
    "declaration": true
  },
  "include": ["src-main/**/*", "shared/**/*", "server/**/*"]
}
